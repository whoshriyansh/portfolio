# Copy to .env.local for local development.
# On Vercel, add these in Project Settings → Environment Variables (do not commit secrets).

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Admin dashboard auth (/server)
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=your-secure-password
ADMIN_SECRET=random-long-secret-for-jwt-signing

# Brevo (newsletter emails) — https://app.brevo.com
BREVO_API_KEY=xkeysib-your-brevo-api-key-here
BREVO_SENDER_EMAIL=hello@yourdomain.com
BREVO_SENDER_NAME=Shriyansh Lohia

# Cloudinary (blog image uploads) — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Optional: folder name for uploaded blog images
CLOUDINARY_FOLDER=portfolio-blog

# Optional: canonical site URL for SEO/sitemap/unsubscribe links
NEXT_PUBLIC_SITE_URL=https://whoshriyansh.vercel.app
